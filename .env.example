# ============================================================
#  UIDT MARKET — Configuration des variables d'environnement
#  Copiez ce fichier : cp .env.example .env
#  et remplissez chaque valeur avec vos vraies clés.
# ============================================================

# ── Base de données Supabase ─────────────────────────────────
DATABASE_URL=postgresql://postgres.[username]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Application ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En production : https://uidt-market.uidt.edu.sn

# ── Google OAuth ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# ── Paiement Wave (Sénégal) ──────────────────────────────────
# Créer un compte marchand : https://www.wave.com/fr/business/
# Documentation API : https://docs.wave.com/
WAVE_API_KEY=wave_sn_xxxxxxxxxxxxxxxxxxxxxxxxx
WAVE_MERCHANT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
WAVE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
# URL de callback après paiement
WAVE_SUCCESS_URL=${NEXT_PUBLIC_APP_URL}/commande/succes
WAVE_ERROR_URL=${NEXT_PUBLIC_APP_URL}/commande/erreur

# ── Paiement Orange Money (Sénégal) ──────────────────────────
# Créer un compte développeur : https://developer.orange.com/
# Documentation : https://developer.orange.com/apis/orange-money-senegal/
ORANGE_MONEY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ORANGE_MONEY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ORANGE_MONEY_MERCHANT_NUMBER=771234567
# Environnement : "sandbox" (test) ou "production"
ORANGE_MONEY_ENV=sandbox

# ── Paiement Free Money (Sénégal) ────────────────────────────
# Contactez Free Sénégal (Expresso) pour les clés API
FREE_MONEY_API_KEY=xxxxxxxxxxxxxxxx
FREE_MONEY_MERCHANT_ID=xxxxxxxxxxxxxxxx

# ── Email (Supabase gère nativement, optionnel) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@uidt.edu.sn
# SMTP_PASS=xxxxxxxxxx

# ── Configuration UIDT ───────────────────────────────────────
NEXT_PUBLIC_UNIVERSITY_NAME="Université Iba Der Thiam de Thiès"
NEXT_PUBLIC_UNIVERSITY_PHONE="+221 33 851 12 34"
NEXT_PUBLIC_UNIVERSITY_EMAIL="contact@uidt.edu.sn"
NEXT_PUBLIC_UNIVERSITY_ADDRESS="BP 967, Thiès, Sénégal"
NEXT_PUBLIC_CURRENCY=FCFA
NEXT_PUBLIC_LOCALE=fr-SN
